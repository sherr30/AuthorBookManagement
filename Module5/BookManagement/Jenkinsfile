pipeline {
    agent any

    environment {
        REGISTRY_REPO = 'your-dockerhub-username/authorbookmanagement'
        IMAGE_TAG = "${env.BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Test') {
            steps {
                dir('Module5/BookManagement') {
                    bat 'mvn test'
                }
            }
        }
        
        stage('Code quality Analysis') {
            steps {
				script{
					echo " Stage: Code Quality Analysis"
					//SonarQube Analysis (if configured)
					//sh 'mvn sonar:sonar
					echo 'code quality check completed'
                }
            }
        }
        
        stage('Package') {
            steps {
                dir('Module5/BookManagement') {
                    bat 'mvn clean package -DskipTests'
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('Module5/BookManagement') {
                    bat """
                    wsl docker build ^
                    -t ${REGISTRY_REPO}:${IMAGE_TAG} ^
                    -t ${REGISTRY_REPO}:latest ^
                    .
                    """
                }
            }
        }
    }

    post {
        success {
            echo "BUILD SUCCESS — image: ${env.REGISTRY_REPO}:${env.IMAGE_TAG}"
        }
        failure {
            echo 'BUILD FAILED'
        }
        always {
            cleanWs()
        }
    }
}
