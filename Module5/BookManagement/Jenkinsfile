pipeline {
    agent any

    environment {
        REGISTRY      = 'docker.io'
        REGISTRY_REPO = 'your-dockerhub-username/authorbookmanagement'
        IMAGE_TAG     = "${env.BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Test') {
            steps {
                dir('Module5/BookManagement') {
                    bat 'mvn test'
                }
            }
            post {
                always {
                    junit 'Module5/BookManagement/target/surefire-reports/*.xml'
                }
            }
        }

        stage('Package') {
            steps {
                dir('Module5/BookManagement') {
                    bat 'mvn clean package -DskipTests'
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('Module5/BookManagement') {
                    bat "docker build -t ${REGISTRY_REPO}:${IMAGE_TAG} -t ${REGISTRY_REPO}:latest ."
                }
            }
        }

        stage('Docker Push') {
            when {
                branch 'main'
            }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-registry-credentials',
                    usernameVariable: 'REGISTRY_USER',
                    passwordVariable: 'REGISTRY_PASS'
                )]) {

                    bat 'docker login -u %REGISTRY_USER% -p %REGISTRY_PASS%'
                    bat "docker push ${REGISTRY_REPO}:${IMAGE_TAG}"
                    bat "docker push ${REGISTRY_REPO}:latest"
                }
            }
        }
    }

    post {
        success {
            echo "BUILD SUCCESS — image: ${env.REGISTRY_REPO}:${env.IMAGE_TAG}"
        }
        failure {
            echo 'BUILD FAILED'
        }
        always {
            cleanWs()
        }
    }
}